{
  "name": "short-link-bot",
  "version": "1.0.0",
  "description": "short link clicker / lead generator",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "run:single": "node run_single.js",
    "server": "node control-server.js",
    "dev": "npx nodemon --watch . --exec node control-server.js",
    "clean": "node -e \"[\"debug_page.html\",\"debug_runs.log\",\"debug_screenshot.png\",\"leads.csv\",\"verified_proxies.json\"].forEach(f=>{try{require('fs').unlinkSync(f);console.log('removed',f)}catch(e){}})\"",
    "audit": "npm audit --json > npm-audit.json || true",
    "audit:fix": "npm audit fix || true"
  },
  "dependencies": {
    "puppeteer": "^23.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "node-fetch": "2.7.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "",
  "license": "ISC"
}
